# Cursor API key (from Cursor Dashboard → Integrations)
CURSOR_API_KEY=

# Optional: Bearer token for auth between you and this proxy
BRIDGE_AUTH_TOKEN=

# Listen config
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8791

# Default model
BRIDGE_DEFAULT_MODEL=composer-2.5

# Working directory for agent context
BRIDGE_WORKSPACE=.

# Agent run timeout
BRIDGE_TIMEOUT_MS=180000
